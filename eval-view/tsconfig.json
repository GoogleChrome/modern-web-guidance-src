{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "allowImportingTsExtensions": true,
    "lib": ["esnext", "dom", "dom.iterable"]
  },
  "include": [
    "server.js",
    "utils.js",
    "evals.d.ts"
  ],
  "exclude": [
    "node_modules",
    "test-results",
    "mock-results"
  ]
}
